function fib(n: Number): Number {
    if (n <= 1) {
        n;
    }
    else {
        fib(n - 1) + fib(n - 2);
    };
}

function abs(x: Number): Number {
    if (x < 0) {
        -x;
    }
    else {
        x;
    };
}

let dummy = 0 in {
    print(2 + 3 * 4);
    print(10 % 3);
    print(2 ^ 10);
    print("Hello" @@ "World");
    print("value=" @ 42);
    print(true & false);
    print(true | false);
    print(!true);
    print(fib(10));
    print(abs(-7));
    print(sqrt(144));
    print(sin(0));
    print(cos(0));
};
